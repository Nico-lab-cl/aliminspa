generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  celular   String
  ciudad    String
  proyecto  String?
  fuente    String   @default("web")
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  utm_content  String?
  utm_term     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("leads")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

model Booking {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  celular   String
  proyecto  String
  fecha     DateTime
  hora      String
  status    String   @default("confirmed")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bookings")
}

model Sorteo {
  id           String   @id @default("current")
  participants String   @db.Text // JSON array of participant usernames
  winners      String   @db.Text // JSON array of winner usernames
  status       String   @default("pending") // pending | active | finished
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("sorteos")
}

model PollVote {
  id         String   @id @default(cuid())
  pollId     String   @map("poll_id")      // Identificador de la encuesta (ej. "lomas-del-mar-beneficio")
  optionId   Int      @map("option_id")    // ID de la opción elegida (1, 2, 3...)
  optionText String   @map("option_text")  // Texto de la opción para referencia
  fingerprint String? @map("fingerprint")  // Hash del IP para evitar duplicados sin guardar datos personales
  userAgent  String?  @map("user_agent")
  proyecto   String?                       // Proyecto asociado (ej. "Lomas del Mar")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([pollId])
  @@index([pollId, fingerprint])
  @@map("poll_votes")
}
